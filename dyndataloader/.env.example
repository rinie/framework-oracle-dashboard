# Oracle connection (via duckdb-oracle extension)
ORACLE_DSN=your_tns_alias
ORACLE_USER=your_user
ORACLE_PASSWORD=your_password

# Sidecar config
PORT=3001
BEARER_TOKEN=change_me_secret

# Poll interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000

# Optional: comma-separated list of datasets to enable
# If unset, all configured datasets are active
# ENABLED_DATASETS=sales,inventory
